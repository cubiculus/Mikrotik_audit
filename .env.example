# MikroTik Router Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit the .env file to version control!

# ==================== Router Configuration ====================
# Router IP address or hostname
MIKROTIK_IP=192.168.1.1

# SSH port (default: 22)
MIKROTIK_PORT=22

# SSH username (default: admin)
MIKROTIK_USER=admin

# SSH password (REQUIRED) - Replace with your actual password
MIKROTIK_PASSWORD=your_password_here

# SSH key authentication (alternative to password)
# MIKROTIK_SSH_KEY_FILE=~/.ssh/id_rsa
# MIKROTIK_SSH_KEY_PASSPHRASE=

# Connection timeouts (seconds)
MIKROTIK_CONNECT_TIMEOUT=30
MIKROTIK_COMMAND_TIMEOUT=120

# ==================== Web Interface Configuration ====================
# Flask secret key (REQUIRED for production web interface)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_flask_secret_key_here

# Web server binding (default: 127.0.0.1 for local only)
# For remote access, set to 0.0.0.0 or specific IP
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Enable debug mode (set to "true" only for development)
FLASK_DEBUG=false

# ==================== External Services ====================
# NIST NVD API key for CVE lookups (optional, increases rate limits)
# Get from: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here
